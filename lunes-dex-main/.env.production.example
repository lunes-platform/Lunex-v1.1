# ═══════════════════════════════════════════════════════════════════════════════
# Lunex DEX Frontend — Production Environment Template
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.production and inject values via your CI/CD pipeline.
# DO NOT commit .env.production with real values.
#
# This file is consumed by `vite build` (mode=production). Values are baked
# into the bundle at build time — there is no runtime override.

# ─── Network ───────────────────────────────────────────────────────────────────
REACT_APP_NETWORK=mainnet
REACT_APP_RPC_TESTNET=wss://ws-test.lunes.io
REACT_APP_RPC_MAINNET=wss://ws.lunes.io

# ─── API Endpoint (PUBLIC URL of spot-api in production) ──────────────────────
# CRITICAL: must NOT be localhost. Example: https://api.lunex.lunes.io
REACT_APP_SPOT_API_URL=

# ─── Core DEX Contracts (mainnet addresses) ───────────────────────────────────
REACT_APP_FACTORY_CONTRACT=
REACT_APP_ROUTER_CONTRACT=
REACT_APP_WNATIVE_CONTRACT=

# ─── Staking + Rewards Contracts ──────────────────────────────────────────────
REACT_APP_STAKING_CONTRACT=
REACT_APP_REWARDS_CONTRACT=

# ─── Copy Trading + Listing Contracts ─────────────────────────────────────────
REACT_APP_COPY_VAULT_CONTRACT=
REACT_APP_LISTING_MANAGER_CONTRACT=
REACT_APP_LIQUIDITY_LOCK_CONTRACT=

# ─── Token Addresses (mainnet) ────────────────────────────────────────────────
REACT_APP_TOKEN_LUNES=
REACT_APP_TOKEN_WLUNES=
REACT_APP_TOKEN_LBTC=
REACT_APP_TOKEN_LETH=
REACT_APP_TOKEN_LUSDT=
REACT_APP_TOKEN_GMC=
REACT_APP_TOKEN_LUP=

# ─── LP Pair Addresses ────────────────────────────────────────────────────────
REACT_APP_LP_TOKEN_WLUNES_LUSDT=
REACT_APP_LP_TOKEN_LBTC_LUSDT=
REACT_APP_LP_TOKEN_LETH_LUSDT=
REACT_APP_LP_TOKEN_GMC_LUSDT=
REACT_APP_LP_TOKEN_LUP_LUSDT=

# ─── Feature Flags ────────────────────────────────────────────────────────────
REACT_APP_ENABLE_STAKING=true
REACT_APP_ENABLE_REWARDS=true
REACT_APP_ENABLE_NATIVE_SWAP=true
REACT_APP_DEV_MODE=false
DISABLE_ESLINT_PLUGIN=true
