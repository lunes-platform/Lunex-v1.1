# Lunex DEX Frontend Configuration
# Copy this file to .env and fill in the values

# ===========================================
# NETWORK CONFIGURATION
# ===========================================
# Available networks: testnet, mainnet
REACT_APP_NETWORK=testnet

# Network RPC endpoints
REACT_APP_RPC_TESTNET=wss://ws-test.lunes.io
REACT_APP_RPC_MAINNET=wss://ws.lunes.io

# ===========================================
# CONTRACT ADDRESSES (Update after deploy)
# ===========================================
# Core DEX Contracts
REACT_APP_FACTORY_CONTRACT=
REACT_APP_ROUTER_CONTRACT=
REACT_APP_WNATIVE_CONTRACT=

# Staking & Rewards Contracts
REACT_APP_STAKING_CONTRACT=
REACT_APP_REWARDS_CONTRACT=

# ===========================================
# TOKEN ADDRESSES (Update after deploy)
# ===========================================
# Native and Wrapped tokens
REACT_APP_TOKEN_LUNES=
REACT_APP_TOKEN_WLUNES=

# Bridged tokens
REACT_APP_TOKEN_LBTC=
REACT_APP_TOKEN_LETH=
REACT_APP_TOKEN_LUSDT=

# Ecosystem tokens
REACT_APP_TOKEN_GMC=
REACT_APP_TOKEN_LUP=

# ===========================================
# LP TOKEN ADDRESSES (Created when pools are created)
# ===========================================
REACT_APP_LP_TOKEN_LUNES_USDT=
REACT_APP_LP_TOKEN_LUNES_BTC=
REACT_APP_LP_TOKEN_LUNES_ETH=

# ===========================================
# FEATURE FLAGS
# ===========================================
REACT_APP_ENABLE_STAKING=true
REACT_APP_ENABLE_REWARDS=true
REACT_APP_ENABLE_NATIVE_SWAP=true

# Development mode (uses mock data when true)
REACT_APP_DEV_MODE=true
