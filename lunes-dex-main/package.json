{
  "name": "lunes-dex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "format:write": "prettier --write \"src/**/*.{ts,tsx}\"",
    "deadcode:exports": "node ./scripts/check-ts-prune.cjs",
    "deadcode:deps": "node ./scripts/check-depcheck.cjs",
    "contract:check": "node ./scripts/check-contract-abi-alignment.cjs",
    "quality": "npm run contract:check && npm run lint && npm run deadcode:exports && npm run deadcode:deps && npm run format:check",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@polkadot/api": "^16.5.3",
    "@polkadot/api-contract": "^16.5.3",
    "@polkadot/extension-dapp": "^0.62.6",
    "@polkadot/extension-inject": "^0.62.6",
    "@polkadot/util": "^13.5.9",
    "@polkadot/util-crypto": "^13.5.9",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.556.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.2.1",
    "recharts": "^3.8.0",
    "styled-components": "^5.3.11"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@types/node": "^18.11.18",
    "@types/react": "^18.0.26",
    "@types/react-dom": "18.0.10",
    "@types/styled-components": "^5.1.26",
    "@vitejs/plugin-react": "^4.3.4",
    "depcheck": "^1.4.7",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.6.2",
    "ts-prune": "^0.10.3",
    "typescript": "^5.3.3",
    "vite": "^6.3.5"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
