# ─────────────────────────────────────────────────────────────────
#  Lunex DEX — Testnet Environment (Public Lunes Testnet)
#  Copie para .env.testnet e preencha todos os valores
#
#  NUNCA commite .env.testnet com valores reais!
# ─────────────────────────────────────────────────────────────────

# ── Banco de dados ────────────────────────────────────────────────
DB_USER=lunex
DB_PASSWORD=change-me-strong-password

# ── Blockchain — Lunes Testnet Pública ────────────────────────────
# Não precisa de nó local — conecta direto na testnet pública
LUNES_TESTNET_WS_URL=wss://testnet.lunes.io

# ── Relayer (carteira dedicada para testnet) ──────────────────────
# NUNCA use a seed de produção aqui
# Gere com: subkey generate --scheme sr25519
RELAYER_SEED=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# ── Segurança ─────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
ADMIN_SECRET=change-me-admin-secret
NEXTAUTH_SECRET=change-me-nextauth-secret

# ── CORS ──────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://lunex-sandbox.lunes.io

# ── URLs ──────────────────────────────────────────────────────────
NEXTAUTH_URL=https://lunex-sandbox.lunes.io/admin

# ── Contratos testnet (preencher após deploy) ─────────────────────
TESTNET_SPOT_CONTRACT=
TESTNET_SPOT_CONTRACT_METADATA_PATH=./abis/Spot.json
TESTNET_FACTORY_CONTRACT=
TESTNET_ROUTER_CONTRACT=
TESTNET_STAKING_CONTRACT=
TESTNET_REWARDS_CONTRACT=
TESTNET_LISTING_MANAGER_CONTRACT=
TESTNET_NATIVE_TOKEN_ADDRESS=

# ── Tokens testnet (preencher após deploy) ────────────────────────
TESTNET_WLUNES_ADDRESS=
TESTNET_LUSDT_ADDRESS=
TESTNET_LBTC_ADDRESS=
TESTNET_LETH_ADDRESS=
TESTNET_GMC_ADDRESS=
TESTNET_LUP_ADDRESS=
