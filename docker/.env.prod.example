# ─────────────────────────────────────────────────────────────────
#  Lunex — variáveis de PRODUÇÃO (mainnet)
#  Copie para .env.prod e preencha TODOS os valores antes do deploy
#  NUNCA commite este arquivo com valores reais
#
#  Uso:
#    docker compose -f docker/docker-compose.prod.yml --env-file docker/.env.prod up -d
#
#  Para sandbox (testnet), use também:
#    docker compose -f docker/docker-compose.prod.yml \
#      -f docker/docker-compose.sandbox.yml \
#      --env-file docker/.env.prod --env-file docker/.env.sandbox up -d
# ─────────────────────────────────────────────────────────────────

# ── Domínios ──────────────────────────────────────────────────────
DOMAIN_PROD=lunex.lunes.io
DOMAIN_SANDBOX=lunex-sandbox.lunes.io
DOMAIN_TESTNET=sandbox.lunes.io

# ── Banco de dados ────────────────────────────────────────────────
DB_USER=lunex
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Blockchain ────────────────────────────────────────────────────
# IP/host do nó Lunes (roda em Docker separado)
LUNES_WS_URL=wss://ws.lunes.io

# Seed da conta relayer (conta que assina settlements on-chain)
RELAYER_SEED=CHANGE_ME_RELAYER_SEED_PHRASE

# ── Contratos deployados (mainnet) ───────────────────────────────
SPOT_CONTRACT_ADDRESS=
SPOT_CONTRACT_METADATA_PATH=./abis/Spot.json
FACTORY_CONTRACT_ADDRESS=
FACTORY_CONTRACT_METADATA_PATH=./abis/Factory.json
NATIVE_TOKEN_ADDRESS=
REACT_APP_FACTORY_CONTRACT=
REACT_APP_ROUTER_CONTRACT=
REACT_APP_STAKING_CONTRACT=
REACT_APP_REWARDS_CONTRACT=

# ── Tokens (mainnet) ──────────────────────────────────────────────
WLUNES_ADDRESS=
LUSDT_ADDRESS=
LBTC_ADDRESS=
LETH_ADDRESS=
GMC_ADDRESS=
LUP_ADDRESS=

# ── RPC mainnet ───────────────────────────────────────────────────
REACT_APP_RPC_MAINNET=wss://ws.lunes.io

# ── Admin (Next.js) ───────────────────────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET
NEXTAUTH_URL=https://lunex.lunes.io/admin

# ── CORS e domínio ────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://lunex.lunes.io,https://lunex-sandbox.lunes.io

# ── Redis ─────────────────────────────────────────────────────────
# Em produção o Redis roda no container interno; deixe o default
REDIS_URL=redis://redis:6379
# Opcional (somente se redis-exporter usar endpoint/senha custom)
REDIS_EXPORTER_ADDR=redis://redis:6379
REDIS_EXPORTER_PASSWORD=

# ── Monitoramento (Grafana) ────────────────────────────────────────
# Gere com: openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ── Backups automáticos (PostgreSQL) ──────────────────────────────
# Deixe S3_BUCKET vazio para backups apenas locais
BACKUP_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
BACKUP_RETENTION_DAYS=7

# ── SubQuery Indexer ───────────────────────────────────────────────
SUBQUERY_ENDPOINT=http://subquery-query:3000
SUBQUERY_ENABLED=false
SUBQUERY_CHAIN_ID=

# ── Token Listing System (deploy contratos e preencha) ─────────────
LISTING_MANAGER_CONTRACT_ADDRESS=
LIQUIDITY_LOCK_CONTRACT_ADDRESS=
