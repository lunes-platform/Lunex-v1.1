# ─────────────────────────────────────────────────────────────────
#  Lunex SANDBOX — variáveis de ambiente (testnet)
#  Copie para .env.sandbox e preencha TODOS os valores
#  NUNCA commite este arquivo com valores reais
#
#  Uso (combinado com prod):
#    docker compose -f docker/docker-compose.prod.yml \
#      -f docker/docker-compose.sandbox.yml \
#      --env-file docker/.env.prod --env-file docker/.env.sandbox up -d
# ─────────────────────────────────────────────────────────────────

# ── Banco de dados (sandbox, separado do prod) ────────────────────
SANDBOX_DB_USER=lunex_sandbox
SANDBOX_DB_PASSWORD=CHANGE_ME_SANDBOX_DB_PASSWORD

# ── Blockchain testnet ────────────────────────────────────────────
SANDBOX_LUNES_WS_URL=wss://ws-test.lunes.io
SANDBOX_RPC_URL=wss://ws-test.lunes.io

# Seed da conta relayer testnet (NÃO use a seed de produção!)
SANDBOX_RELAYER_SEED=CHANGE_ME_SANDBOX_RELAYER_SEED

# ── Contratos deployados (testnet) ───────────────────────────────
SANDBOX_FACTORY_CONTRACT=
SANDBOX_ROUTER_CONTRACT=
SANDBOX_STAKING_CONTRACT=
SANDBOX_REWARDS_CONTRACT=

# ── Tokens (testnet) ──────────────────────────────────────────────
SANDBOX_WLUNES_ADDRESS=
SANDBOX_LUSDT_ADDRESS=
SANDBOX_LBTC_ADDRESS=
SANDBOX_LETH_ADDRESS=
SANDBOX_GMC_ADDRESS=
SANDBOX_LUP_ADDRESS=

# ── CORS (sandbox) ───────────────────────────────────────────────
SANDBOX_CORS_ORIGINS=https://lunex-sandbox.lunes.io

# ── Testnet node image ────────────────────────────────────────────
LUNES_TESTNET_NODE_IMAGE=lunesproject/lunes-nightly:latest
