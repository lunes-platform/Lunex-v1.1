# ── Stage 1: Build ──
FROM node:20-alpine AS builder
WORKDIR /app

# Build-time args — baked into the CRA bundle
ARG REACT_APP_NETWORK=testnet
ARG REACT_APP_SPOT_API_URL=""
ARG REACT_APP_RPC_TESTNET=ws://localhost:9944
ARG REACT_APP_RPC_MAINNET=wss://ws.lunes.io
ARG REACT_APP_FACTORY_CONTRACT=""
ARG REACT_APP_ROUTER_CONTRACT=""
ARG REACT_APP_STAKING_CONTRACT=""
ARG REACT_APP_REWARDS_CONTRACT=""
ARG REACT_APP_TOKEN_WLUNES=""
ARG REACT_APP_TOKEN_LUSDT=""
ARG REACT_APP_TOKEN_LBTC=""
ARG REACT_APP_TOKEN_LETH=""
ARG REACT_APP_TOKEN_GMC=""
ARG REACT_APP_TOKEN_LUP=""
ARG REACT_APP_ENABLE_STAKING=true
ARG REACT_APP_ENABLE_REWARDS=true
ARG REACT_APP_DEV_MODE=false

ENV REACT_APP_NETWORK=$REACT_APP_NETWORK \
    REACT_APP_SPOT_API_URL=$REACT_APP_SPOT_API_URL \
    REACT_APP_RPC_TESTNET=$REACT_APP_RPC_TESTNET \
    REACT_APP_RPC_MAINNET=$REACT_APP_RPC_MAINNET \
    REACT_APP_FACTORY_CONTRACT=$REACT_APP_FACTORY_CONTRACT \
    REACT_APP_ROUTER_CONTRACT=$REACT_APP_ROUTER_CONTRACT \
    REACT_APP_STAKING_CONTRACT=$REACT_APP_STAKING_CONTRACT \
    REACT_APP_REWARDS_CONTRACT=$REACT_APP_REWARDS_CONTRACT \
    REACT_APP_TOKEN_WLUNES=$REACT_APP_TOKEN_WLUNES \
    REACT_APP_TOKEN_LUSDT=$REACT_APP_TOKEN_LUSDT \
    REACT_APP_TOKEN_LBTC=$REACT_APP_TOKEN_LBTC \
    REACT_APP_TOKEN_LETH=$REACT_APP_TOKEN_LETH \
    REACT_APP_TOKEN_GMC=$REACT_APP_TOKEN_GMC \
    REACT_APP_TOKEN_LUP=$REACT_APP_TOKEN_LUP \
    REACT_APP_ENABLE_STAKING=$REACT_APP_ENABLE_STAKING \
    REACT_APP_ENABLE_REWARDS=$REACT_APP_ENABLE_REWARDS \
    REACT_APP_DEV_MODE=$REACT_APP_DEV_MODE

COPY package*.json package-lock.json ./
RUN npm ci --production=false
COPY . .
ENV CI=false
RUN npm run build

# ── Stage 2: Serve with nginx ──
FROM nginx:1.25-alpine AS runner
COPY --from=builder /app/build /usr/share/nginx/html
COPY docker/nginx.spa.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
