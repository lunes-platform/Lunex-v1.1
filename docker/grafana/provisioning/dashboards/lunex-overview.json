      "targets": [{ "expr": "lunex_vault_total_equity", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Rate (per route)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "id": 10,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_request_duration_seconds_count[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP p99 Latency",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "id": 11,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (route, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Error Rate (status >= 500)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "id": 12,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_request_duration_seconds_count{status_code=~\"5..\"}[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "PostgreSQL Connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
