# ─────────────────────────────────────────────────────────────────
#  Lunex — Variáveis de ambiente para Docker local (dev)
#  Copie para docker/.env.docker e ajuste os valores
#
#  NUNCA commite este arquivo com valores reais!
# ─────────────────────────────────────────────────────────────────

# ── Blockchain ────────────────────────────────────────────────────
# Nó Lunes local (substrate-contracts-node --dev)
# Dentro do Docker, use host.docker.internal para alcançar o host
LUNES_WS_URL=ws://host.docker.internal:9944

# ── Segurança ─────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
ADMIN_SECRET=change-me-dev-admin-secret

# Seed da conta relayer (para dev, use Alice)
RELAYER_SEED=bottom drive obey lake curtain smoke basket hold race lonely fit walk//Alice

# ── Admin (NextAuth.js) ───────────────────────────────────────────
NEXTAUTH_SECRET=change-me-nextauth-secret-min-32-chars

# ── SubQuery ──────────────────────────────────────────────────────
SUBQUERY_ENDPOINT=http://subquery-query:3000
SUBQUERY_ENABLED=true

# ── Contratos ink! deployed (preencher após deploy) ───────────────
REACT_APP_FACTORY_CONTRACT=
REACT_APP_ROUTER_CONTRACT=
REACT_APP_STAKING_CONTRACT=
REACT_APP_REWARDS_CONTRACT=

WLUNES_ADDRESS=
LUSDT_ADDRESS=
LBTC_ADDRESS=
LETH_ADDRESS=
GMC_ADDRESS=
LUP_ADDRESS=

# ── Feature flags ─────────────────────────────────────────────────
REACT_APP_DEV_MODE=true
SOCIAL_ANALYTICS_ENABLED=true
