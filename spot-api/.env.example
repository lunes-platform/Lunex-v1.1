# Database (⚠️ change credentials for production!)
DATABASE_URL="postgresql://user:password@localhost:5432/lunex_spot?schema=public"

# Server
PORT=4000
NODE_ENV=development

# Security
CORS_ALLOWED_ORIGINS="http://localhost:3001,http://localhost:3000"
TRUST_PROXY=false
NODE_ENV=development

# WebSocket
WS_PORT=4001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
ORDER_RATE_LIMIT_MAX=10

# Blockchain (Lunes Node)
LUNES_WS_URL="ws://127.0.0.1:9944"
SPOT_CONTRACT_ADDRESS=""

# Social analytics pipeline
SOCIAL_ANALYTICS_ENABLED=false
SOCIAL_ANALYTICS_CHAIN_NAME="lunes"
SOCIAL_ANALYTICS_START_BLOCK=0
SOCIAL_ANALYTICS_BACKFILL_BLOCKS=2000
SOCIAL_ANALYTICS_POLL_INTERVAL_MS=15000
SOCIAL_ANALYTICS_MAX_BLOCKS_PER_RUN=100
SOCIAL_ANALYTICS_TRACKED_PALLETS="router,factory,pair,market,orders,copytrade,social"
SOCIAL_ANALYTICS_TRACKED_METHODS="swapexecuted,liquidityadded,liquidityremoved,tradeopened,tradeclosed,deposit,withdraw"

# SubQuery Indexer (recommended — faster and more reliable than direct RPC polling)
# When set, socialIndexerService uses SubQuery GraphQL as primary event source.
# Leave empty to fall back to direct Polkadot.js RPC polling (legacy mode).
SUBQUERY_ENDPOINT=""
# SUBQUERY_ENDPOINT="http://localhost:3000"     # local docker
# SUBQUERY_ENDPOINT="https://subquery.lunex.io" # production
SUBQUERY_ENABLED=true
SUBQUERY_CHAIN_ID=""    # output of: subkey inspect --network substrate (genesis hash)

# Relayer private key (for submitting settlements on-chain)
RELAYER_SEED=""

# Redis (replay protection nonce store + cache)
# In production this points to the Redis container
REDIS_URL="redis://127.0.0.1:6379"
# TTL in seconds for replay-protection nonces (default: 5 minutes)
NONCE_TTL_SECONDS=300

# Vault Reconciliation
# Set to "true" to enable the periodic job that detects and repairs DB drift
VAULT_RECONCILIATION_ENABLED=false
VAULT_RECONCILIATION_INTERVAL_MS=60000

# Structured Logging (pino)
# Levels: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Admin secret (required for pair registration and other admin routes)
# Generate with: openssl rand -base64 32
ADMIN_SECRET=""

# Contract addresses (fill after deployment)
FACTORY_CONTRACT_ADDRESS=""
FACTORY_CONTRACT_METADATA_PATH="./abis/Factory.json"
NATIVE_TOKEN_ADDRESS=""

# Listing System (fill after deploying listing contracts)
LISTING_MANAGER_CONTRACT_ADDRESS=""
LIQUIDITY_LOCK_CONTRACT_ADDRESS=""
