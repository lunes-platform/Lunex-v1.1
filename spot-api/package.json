{
  "name": "lunex-spot-api",
  "version": "0.1.0",
  "description": "Lunex DEX Spot Orderbook API - Off-chain matching engine with on-chain settlement",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format:check": "prettier --check \"src/**/*.ts\" \"prisma/**/*.ts\"",
    "format:write": "prettier --write \"src/**/*.ts\" \"prisma/**/*.ts\"",
    "deadcode:exports": "node ./scripts/check-ts-prune.cjs",
    "deadcode:deps": "node ./scripts/check-depcheck.cjs",
    "quality": "npm run lint && npm run deadcode:exports && npm run deadcode:deps && npm run format:check",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:push:reset": "prisma db push --force-reset",
    "db:seed": "prisma db seed",
    "db:recover": "npm run db:push:reset && npm run db:seed",
    "dev:reset-and-start": "npm run db:recover && npm run build && npm start",
    "test": "jest --forceExit --detectOpenHandles",
    "test:e2e": "jest --testPathPattern e2e --forceExit --detectOpenHandles",
    "test:unit": "jest --testPathIgnorePatterns /__tests__/e2e/ --forceExit --detectOpenHandles",
    "test:watch": "jest --watch"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@polkadot/api": "16.5.3",
    "@polkadot/api-contract": "16.5.3",
    "@polkadot/keyring": "13.5.9",
    "@polkadot/util": "13.5.9",
    "@polkadot/util-crypto": "13.5.9",
    "@prisma/client": "^5.10.0",
    "@types/multer": "^2.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.0",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.10",
    "depcheck": "^1.4.7",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "node-fetch": "^3.3.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.6.2",
    "prisma": "^5.10.0",
    "supertest": "^7.2.2",
    "ts-prune": "^0.10.3",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
