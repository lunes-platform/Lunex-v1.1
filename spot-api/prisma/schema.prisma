generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  LIMIT
  MARKET
  STOP
  STOP_LIMIT
}

enum OrderStatus {
  PENDING_TRIGGER
  OPEN
  PARTIAL
  FILLED
  CANCELLED
}

enum TimeInForce {
  GTC
  IOC
  FOK
}

enum MarginPositionStatus {
  OPEN
  CLOSED
  LIQUIDATED
}

enum MarginTransferDirection {
  DEPOSIT
  WITHDRAW
}

enum TransferStatus {
  PENDING
  CONFIRMED
  FAILED
  CANCELLED
}

enum TradeSettlementStatus {
  PENDING
  SETTLING
  SETTLED
  FAILED
  SKIPPED
}

enum CopyVaultStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum CopyTradeSource {
  API
  WEB3
}

enum CopyTradeSignalStatus {
  PENDING_WALLET_SIGNATURE
  EXECUTED
  TWAP_EXECUTED
  FAILED
  CANCELLED
}

enum CopyTradeExecutionStatus {
  EXECUTED
  FAILED
  CANCELLED
}

enum CopyTradeWalletContinuationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum LeaderTradeStatus {
  OPEN
  CLOSED
}

enum SocialIdeaDirection {
  Bullish
  Bearish
}

enum AnalyticsPipelineStatus {
  IDLE
  RUNNING
  ERROR
  DISABLED
}

enum IndexedEventKind {
  SWAP
  LIQUIDITY_ADD
  LIQUIDITY_REMOVE
  TRADE_OPEN
  TRADE_CLOSE
  VAULT_DEPOSIT
  VAULT_WITHDRAW
  ASYMMETRIC_SWAP  // Emitted by AsymmetricPair ink! contract
  UNKNOWN
}

// ─── AI Trading Network ─────────────────────────────────────────

enum StrategyType {
  COPYTRADE     // Mirrors a human/bot leader via CopyVault
  MARKET_MAKER  // Asymmetric liquidity provision
  ARBITRAGE     // Cross-pair / cross-venue arbitrage
  MOMENTUM      // Trend-following
  HEDGE         // Delta-neutral / risk reduction
  CUSTOM        // User-defined
}

enum StrategyRiskLevel {
  LOW
  MEDIUM
  HIGH
  AGGRESSIVE
}

enum StrategyStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

// ─── Agent Ecosystem ────────────────────────────────────────────

enum AgentType {
  HUMAN
  AI_AGENT
  OPENCLAW_BOT
  ALGO_BOT
}

enum AgentStakeStatus {
  PENDING_VERIFICATION  // txHash submitted but not yet verified on-chain
  STAKED
  UNSTAKING
  UNSTAKED
  SLASHED
}

enum AgentApiKeyPermission {
  TRADE_SPOT
  TRADE_MARGIN
  SOCIAL_POST
  COPYTRADE_SIGNAL
  READ_ONLY
  MANAGE_ASYMMETRIC  // Manager scope for AsymmetricPair contracts — curve params only, never funds
}

model Pair {
  id             String   @id @default(uuid())
  symbol         String   @unique
  baseToken      String
  quoteToken     String
  pairAddress    String?  // LP Pair contract address on-chain (returned by Factory.get_pair)
  baseName       String
  quoteName      String
  baseDecimals   Int      @default(8)
  quoteDecimals  Int      @default(8)
  isNativeBase   Boolean  @default(false)
  isNativeQuote  Boolean  @default(false)
  isActive       Boolean  @default(true)
  makerFeeBps    Int      @default(10)
  takerFeeBps    Int      @default(25)
  createdAt      DateTime @default(now())

  orders  Order[]
  trades  Trade[]
  candles Candle[]
  marginPositions MarginPosition[]
  copyTradeSignals CopyTradeSignal[]
  copyTradeExecutions CopyTradeExecution[]
  leaderTrades LeaderTrade[]
  socialIdeas SocialIdea[]
}

model Order {
  id              String    @id @default(uuid())
  pairId          String
  makerAddress    String
  side            OrderSide
  type            OrderType
  price           Decimal   @db.Decimal(36, 18)
  stopPrice       Decimal?  @db.Decimal(36, 18)
  amount          Decimal   @db.Decimal(36, 18)
  filledAmount    Decimal   @default(0) @db.Decimal(36, 18)
  remainingAmount Decimal   @db.Decimal(36, 18)
  status          OrderStatus @default(OPEN)
  signature       String
  nonce           String
  orderHash       String    @unique
  timeInForce     TimeInForce @default(GTC)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  pair        Pair    @relation(fields: [pairId], references: [id])
  makerTrades Trade[] @relation("MakerTrades")
  takerTrades Trade[] @relation("TakerTrades")

  @@index([pairId, side, status, price])
  @@index([makerAddress, status])
  @@unique([makerAddress, nonce])
  @@index([orderHash])
}

model Trade {
  id           String    @id @default(uuid())
  pairId       String
  makerOrderId String
  takerOrderId String
  makerAddress String
  takerAddress String
  side         OrderSide
  price        Decimal   @db.Decimal(36, 18)
  amount       Decimal   @db.Decimal(36, 18)
  quoteAmount  Decimal   @db.Decimal(36, 18)
  makerFee     Decimal   @db.Decimal(36, 18)
  takerFee     Decimal   @db.Decimal(36, 18)
  settlementStatus        TradeSettlementStatus @default(PENDING)
  settlementAttempts      Int      @default(0)
  settlementPayload       Json?
  settlementError         String?
  lastSettlementAttemptAt DateTime?
  nextSettlementRetryAt   DateTime?
  txHash       String?   @unique
  settledAt    DateTime?
  createdAt    DateTime  @default(now())

  pair       Pair  @relation(fields: [pairId], references: [id])
  makerOrder Order @relation("MakerTrades", fields: [makerOrderId], references: [id])
  takerOrder Order @relation("TakerTrades", fields: [takerOrderId], references: [id])

  @@index([pairId, createdAt])
  @@index([makerAddress])
  @@index([takerAddress])
  @@index([settlementStatus, nextSettlementRetryAt])
}

model Candle {
  id          String   @id @default(uuid())
  pairId      String
  timeframe   String
  openTime    DateTime
  open        Decimal  @db.Decimal(36, 18)
  high        Decimal  @db.Decimal(36, 18)
  low         Decimal  @db.Decimal(36, 18)
  close       Decimal  @db.Decimal(36, 18)
  volume      Decimal  @db.Decimal(36, 18)
  quoteVolume Decimal  @db.Decimal(36, 18)
  tradeCount  Int      @default(0)

  pair Pair @relation(fields: [pairId], references: [id])

  @@unique([pairId, timeframe, openTime])
  @@index([pairId, timeframe, openTime])
}

model UserBalance {
  id        String   @id @default(uuid())
  address   String
  token     String
  available Decimal  @default(0) @db.Decimal(36, 18)
  locked    Decimal  @default(0) @db.Decimal(36, 18)
  updatedAt DateTime @updatedAt

  @@unique([address, token])
  @@index([address])
}

model MarginAccount {
  id                  String                     @id @default(uuid())
  address             String                     @unique
  collateralToken     String                     @default("USDT")
  collateralAvailable Decimal                    @default(0) @db.Decimal(36, 18)
  collateralLocked    Decimal                    @default(0) @db.Decimal(36, 18)
  totalRealizedPnl    Decimal                    @default(0) @db.Decimal(36, 18)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  positions           MarginPosition[]
  transfers           MarginCollateralTransfer[]

  @@index([address])
}

model MarginPosition {
  id                String               @id @default(uuid())
  accountId         String
  pairId            String
  pairSymbol        String
  side              OrderSide
  status            MarginPositionStatus @default(OPEN)
  collateralAmount  Decimal              @db.Decimal(36, 18)
  leverage          Decimal              @db.Decimal(20, 8)
  notional          Decimal              @db.Decimal(36, 18)
  quantity          Decimal              @db.Decimal(36, 18)
  entryPrice        Decimal              @db.Decimal(36, 18)
  markPrice         Decimal              @db.Decimal(36, 18)
  borrowedAmount    Decimal              @db.Decimal(36, 18)
  maintenanceMargin Decimal              @db.Decimal(36, 18)
  liquidationPrice  Decimal              @db.Decimal(36, 18)
  unrealizedPnl     Decimal              @default(0) @db.Decimal(36, 18)
  realizedPnl       Decimal              @default(0) @db.Decimal(36, 18)
  openedAt          DateTime             @default(now())
  closedAt          DateTime?
  updatedAt         DateTime             @updatedAt

  account           MarginAccount        @relation(fields: [accountId], references: [id])
  pair              Pair                 @relation(fields: [pairId], references: [id])
  liquidations      MarginLiquidation[]

  @@index([accountId, status])
  @@index([accountId, pairId, status])
  @@index([pairSymbol, status])
}

model MarginCollateralTransfer {
  id          String        @id @default(uuid())
  accountId   String
  direction   MarginTransferDirection
  status      TransferStatus @default(CONFIRMED)
  token       String
  amount      Decimal       @db.Decimal(36, 18)
  signature   String
  txHash      String?
  createdAt   DateTime      @default(now())

  account     MarginAccount @relation(fields: [accountId], references: [id])

  @@index([accountId, createdAt])
  @@index([accountId, status, createdAt])
}

model MarginLiquidation {
  id                 String         @id @default(uuid())
  positionId         String
  liquidatorAddress  String
  markPrice          Decimal        @db.Decimal(36, 18)
  equityBefore       Decimal        @db.Decimal(36, 18)
  penaltyAmount      Decimal        @db.Decimal(36, 18)
  releasedCollateral Decimal        @db.Decimal(36, 18)
  createdAt          DateTime       @default(now())

  position           MarginPosition @relation(fields: [positionId], references: [id])

  @@index([positionId, createdAt])
  @@index([liquidatorAddress, createdAt])
}

model Leader {
  id                         String    @id @default(uuid())
  name                       String
  username                   String    @unique
  address                    String    @unique
  avatar                     String    @default("")
  twitterUrl                 String?
  telegramUrl                String?
  discordUrl                 String?
  isAi                       Boolean   @default(false)
  isVerified                 Boolean   @default(false)
  bio                        String    @db.Text
  memberSince                DateTime  @default(now())
  performanceFeeBps          Int       @default(1500)
  roi30d                     Decimal   @default(0) @db.Decimal(20, 8)
  roi90d                     Decimal   @default(0) @db.Decimal(20, 8)
  totalAum                   Decimal   @default(0) @db.Decimal(36, 18)
  drawdown                   Decimal   @default(0) @db.Decimal(20, 8)
  followersCount             Int       @default(0)
  winRate                    Decimal   @default(0) @db.Decimal(20, 8)
  avgProfit                  Decimal   @default(0) @db.Decimal(20, 8)
  sharpe                     Decimal   @default(0) @db.Decimal(20, 8)
  totalPerformanceFeesEarned Decimal   @default(0) @db.Decimal(36, 18)
  allowApiTrading            Boolean   @default(false)
  apiKeyHash                 String?   @unique
  pnlHistory                 Float[]   @default([])
  tags                       String[]  @default([])
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  vault              CopyVault?
  trades             LeaderTrade[]
  ideas              SocialIdea[]
  follows            LeaderFollow[]
  signals            CopyTradeSignal[]
  analyticsSnapshots LeaderAnalyticsSnapshot[]
  agent              Agent?
  strategies         Strategy[]

  @@index([isAi, roi30d])
  @@index([followersCount, roi30d])
}

model CopyVault {
  id               String    @id @default(uuid())
  leaderId         String    @unique
  name             String
  collateralToken  String    @default("USDT")
  status           CopyVaultStatus @default(ACTIVE)
  totalEquity      Decimal   @default(0) @db.Decimal(36, 18)
  totalShares      Decimal   @default(0) @db.Decimal(36, 18)
  totalDeposits    Decimal   @default(0) @db.Decimal(36, 18)
  totalWithdrawals Decimal   @default(0) @db.Decimal(36, 18)
  minDeposit       Decimal   @default(10) @db.Decimal(36, 18)
  twapThreshold    Decimal   @default(50000) @db.Decimal(36, 18)
  maxSlippageBps   Int       @default(100)
  contractAddress  String?   // On-chain CopyVault ink! contract address
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  leader      Leader               @relation(fields: [leaderId], references: [id])
  positions   CopyVaultPosition[]
  deposits    CopyVaultDeposit[]
  withdrawals CopyVaultWithdrawal[]
  signals     CopyTradeSignal[]
  executions  CopyTradeExecution[]

  @@index([status])
}

model CopyVaultPosition {
  id                String    @id @default(uuid())
  vaultId           String
  followerAddress   String
  shareBalance      Decimal   @default(0) @db.Decimal(36, 18)
  netDeposited      Decimal   @default(0) @db.Decimal(36, 18)
  totalWithdrawn    Decimal   @default(0) @db.Decimal(36, 18)
  highWaterMarkValue Decimal  @default(0) @db.Decimal(36, 18)
  feePaid           Decimal   @default(0) @db.Decimal(36, 18)
  realizedPnl       Decimal   @default(0) @db.Decimal(36, 18)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  vault CopyVault @relation(fields: [vaultId], references: [id])

  @@unique([vaultId, followerAddress])
  @@index([followerAddress])
}

model CopyVaultDeposit {
  id              String    @id @default(uuid())
  vaultId         String
  followerAddress String
  token           String
  amount          Decimal   @db.Decimal(36, 18)
  sharesMinted    Decimal   @db.Decimal(36, 18)
  txHash          String?
  createdAt       DateTime  @default(now())

  vault CopyVault @relation(fields: [vaultId], references: [id])

  @@index([vaultId, createdAt])
  @@index([followerAddress, createdAt])
}

model CopyVaultWithdrawal {
  id              String    @id @default(uuid())
  vaultId         String
  followerAddress String
  token           String
  sharesBurned    Decimal   @db.Decimal(36, 18)
  grossAmount     Decimal   @db.Decimal(36, 18)
  feeAmount       Decimal   @db.Decimal(36, 18)
  netAmount       Decimal   @db.Decimal(36, 18)
  profitAmount    Decimal   @db.Decimal(36, 18)
  txHash          String?
  createdAt       DateTime  @default(now())

  vault CopyVault @relation(fields: [vaultId], references: [id])

  @@index([vaultId, createdAt])
  @@index([followerAddress, createdAt])
}

model CopyTradeSignal {
  id             String    @id @default(uuid())
  leaderId       String
  vaultId        String
  pairId         String?
  pairSymbol     String
  side           OrderSide
  source         CopyTradeSource @default(API)
  strategyTag    String?
  amountIn       Decimal   @db.Decimal(36, 18)
  amountOutMin   Decimal   @db.Decimal(36, 18)
  executionPrice Decimal?  @db.Decimal(36, 18)
  realizedPnlPct Decimal?  @db.Decimal(20, 8)
  route          String[]  @default([])
  maxSlippageBps Int       @default(100)
  status         CopyTradeSignalStatus @default(EXECUTED)
  createdAt      DateTime  @default(now())

  leader     Leader               @relation(fields: [leaderId], references: [id])
  vault      CopyVault            @relation(fields: [vaultId], references: [id])
  pair       Pair?                @relation(fields: [pairId], references: [id])
  walletContinuation CopyTradeWalletContinuation?
  executions CopyTradeExecution[]

  @@index([leaderId, createdAt])
  @@index([vaultId, createdAt])
  @@index([pairId, createdAt])
}

model CopyTradeWalletContinuation {
  id                     String                            @id @default(uuid())
  signalId               String                            @unique
  leaderId               String
  vaultId                String
  positionEffect         String
  executedVia            String                            @default("ASYMMETRIC")
  requiresWalletSignature Boolean                          @default(true)
  contractAddress        String
  method                 String                            @default("swap")
  side                   OrderSide
  amountIn               Decimal                           @db.Decimal(36, 18)
  minAmountOut           Decimal                           @db.Decimal(36, 18)
  makerAddress           String
  nonce                  String
  agentId                String?
  status                 CopyTradeWalletContinuationStatus @default(PENDING)
  txHash                 String?
  message                String?                           @db.Text
  requestedAt            DateTime                          @default(now())
  confirmedAt            DateTime?
  expiresAt              DateTime?
  createdAt              DateTime                          @default(now())
  updatedAt              DateTime                          @updatedAt

  signal                 CopyTradeSignal                   @relation(fields: [signalId], references: [id])

  @@index([leaderId, status, requestedAt])
  @@index([vaultId, status, requestedAt])
}

model CopyTradeExecution {
  id             String    @id @default(uuid())
  vaultId        String
  signalId       String
  pairId         String?
  pairSymbol     String
  side           OrderSide
  sliceIndex     Int
  totalSlices    Int
  amountIn       Decimal   @db.Decimal(36, 18)
  amountOut      Decimal?  @db.Decimal(36, 18)
  executionPrice Decimal?  @db.Decimal(36, 18)
  slippageBps    Int?
  realizedPnl    Decimal   @default(0) @db.Decimal(36, 18)
  status         CopyTradeExecutionStatus @default(EXECUTED)
  createdAt      DateTime  @default(now())

  vault  CopyVault       @relation(fields: [vaultId], references: [id])
  signal CopyTradeSignal @relation(fields: [signalId], references: [id])
  pair   Pair?           @relation(fields: [pairId], references: [id])

  @@index([vaultId, createdAt])
  @@index([signalId])
  @@index([pairId, createdAt])
}

model LeaderTrade {
  id         String    @id @default(uuid())
  leaderId   String
  pairId     String?
  pairSymbol String
  side       OrderSide
  entryPrice Decimal   @db.Decimal(36, 18)
  exitPrice  Decimal?  @db.Decimal(36, 18)
  pnlPct     Decimal   @default(0) @db.Decimal(20, 8)
  status     LeaderTradeStatus @default(OPEN)
  openedAt   DateTime  @default(now())
  closedAt   DateTime?

  leader Leader @relation(fields: [leaderId], references: [id])
  pair   Pair?  @relation(fields: [pairId], references: [id])

  @@index([leaderId, openedAt])
  @@index([pairId, openedAt])
}

model SocialIdea {
  id            String              @id @default(uuid())
  leaderId      String
  pairId        String?
  title         String
  description   String              @db.Text
  pairSymbol    String
  direction     SocialIdeaDirection
  likesCount    Int                 @default(0)
  commentsCount Int                 @default(0)
  tags          String[]            @default([])
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  leader   Leader              @relation(fields: [leaderId], references: [id])
  pair     Pair?               @relation(fields: [pairId], references: [id])
  likes    SocialIdeaLike[]
  comments SocialIdeaComment[]

  @@index([leaderId, createdAt])
  @@index([pairSymbol, createdAt])
  @@index([pairId, createdAt])
}

model SocialIdeaLike {
  id        String    @id @default(uuid())
  ideaId     String
  address   String
  createdAt DateTime  @default(now())

  idea SocialIdea @relation(fields: [ideaId], references: [id])

  @@unique([ideaId, address])
  @@index([address])
}

model SocialIdeaComment {
  id        String    @id @default(uuid())
  ideaId     String
  address   String
  content   String    @db.Text
  createdAt DateTime  @default(now())

  idea SocialIdea @relation(fields: [ideaId], references: [id])

  @@index([ideaId, createdAt])
  @@index([address])
}

model LeaderFollow {
  id              String    @id @default(uuid())
  leaderId        String
  followerAddress String
  createdAt       DateTime  @default(now())

  leader Leader @relation(fields: [leaderId], references: [id])

  @@unique([leaderId, followerAddress])
  @@index([followerAddress])
}

model SocialAnalyticsCursor {
  id                 String                 @id @default(uuid())
  chain              String                 @unique
  lastProcessedBlock Int                    @default(0)
  lastProcessedHash  String?
  status             AnalyticsPipelineStatus @default(IDLE)
  lastProcessedAt    DateTime?
  lastError          String?                @db.Text
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
}

model SocialIndexedEvent {
  id                  String           @id @default(uuid())
  chain               String
  blockNumber         Int
  blockHash           String
  eventIndex          Int
  extrinsicIndex      Int?
  extrinsicHash       String?
  pallet              String
  method              String
  kind                IndexedEventKind @default(UNKNOWN)
  accountAddress      String?
  counterpartyAddress String?
  pairSymbol          String?
  amountIn            Decimal?         @db.Decimal(36, 18)
  amountOut           Decimal?         @db.Decimal(36, 18)
  price               Decimal?         @db.Decimal(36, 18)
  realizedPnl         Decimal?         @db.Decimal(36, 18)
  timestamp           DateTime
  payload             Json
  createdAt           DateTime         @default(now())

  @@unique([chain, blockNumber, eventIndex])
  @@index([accountAddress, timestamp])
  @@index([kind, timestamp])
  @@index([pairSymbol, timestamp])
}

model LeaderAnalyticsSnapshot {
  id             String   @id @default(uuid())
  leaderId       String
  sourceChain    String
  sourceMode     String   @default("INDEXER")
  asOfBlock      Int      @default(0)
  asOfTime       DateTime
  initialEquity  Decimal  @default(0) @db.Decimal(36, 18)
  currentEquity  Decimal  @default(0) @db.Decimal(36, 18)
  realizedPnl    Decimal  @default(0) @db.Decimal(36, 18)
  unrealizedPnl  Decimal  @default(0) @db.Decimal(36, 18)
  tradedVolume   Decimal  @default(0) @db.Decimal(36, 18)
  grossProfit    Decimal  @default(0) @db.Decimal(36, 18)
  grossLoss      Decimal  @default(0) @db.Decimal(36, 18)
  roi30d         Decimal  @default(0) @db.Decimal(20, 8)
  roi90d         Decimal  @default(0) @db.Decimal(20, 8)
  maxDrawdown    Decimal  @default(0) @db.Decimal(20, 8)
  winRate        Decimal  @default(0) @db.Decimal(20, 8)
  avgProfit      Decimal  @default(0) @db.Decimal(20, 8)
  sharpe         Decimal  @default(0) @db.Decimal(20, 8)
  totalTrades    Int      @default(0)
  winningTrades  Int      @default(0)
  losingTrades   Int      @default(0)
  pnlHistory     Float[]  @default([])
  lastEventAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  leader Leader @relation(fields: [leaderId], references: [id])

  @@unique([leaderId, sourceChain])
  @@index([asOfBlock])
  @@index([asOfTime])
}

// ─── Affiliate Program ───────────────────────────────────────────

enum AffiliateSourceType {
  SPOT
  MARGIN
  COPYTRADE
}

enum AffiliatePayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Referral {
  id              String   @id @default(uuid())
  referrerAddress String
  refereeAddress  String   @unique
  referralCode    String
  level           Int      @default(1)
  createdAt       DateTime @default(now())

  @@index([referrerAddress])
  @@index([referralCode])
}

model AffiliateCommission {
  id               String              @id @default(uuid())
  beneficiaryAddr  String
  sourceAddr       String
  sourceTradeId    String?
  sourceType       AffiliateSourceType
  level            Int
  feeToken         String
  feeAmount        Decimal             @db.Decimal(36, 18)
  commissionRate   Int
  commissionAmount Decimal             @db.Decimal(36, 18)
  batchId          String?
  isPaid           Boolean             @default(false)
  createdAt        DateTime            @default(now())

  batch AffiliatePayoutBatch? @relation(fields: [batchId], references: [id])

  @@index([beneficiaryAddr, isPaid])
  @@index([sourceAddr, createdAt])
  @@index([batchId])
}

model AffiliatePayoutBatch {
  id          String                @id @default(uuid())
  periodStart DateTime
  periodEnd   DateTime
  totalPaid   Decimal               @default(0) @db.Decimal(36, 18)
  status      AffiliatePayoutStatus @default(PENDING)
  processedAt DateTime?
  createdAt   DateTime              @default(now())

  commissions AffiliateCommission[]

  @@index([status])
}

// ─── Agent Ecosystem ────────────────────────────────────────────

model Agent {
  id                   String      @id @default(uuid())
  leaderId             String?     @unique
  walletAddress        String      @unique
  agentType            AgentType   @default(HUMAN)
  framework            String?
  strategyDescription  String?     @db.Text
  isActive             Boolean     @default(true)
  isBanned             Boolean     @default(false)
  banReason            String?

  // Trading limits (determined by staking tier)
  dailyTradeLimit      Int         @default(10)
  maxPositionSize      Decimal     @default(100) @db.Decimal(36, 18)
  maxOpenOrders        Int         @default(5)

  // Staking
  stakedAmount         Decimal     @default(0) @db.Decimal(36, 18)
  stakingTier          Int         @default(0)

  // Activity
  totalTrades          Int         @default(0)
  totalVolume          Decimal     @default(0) @db.Decimal(36, 18)
  lastActiveAt         DateTime?
  /// Reputation score computed from strategy performance (0-100)
  reputationScore      Decimal     @default(0) @db.Decimal(10, 4)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  leader               Leader?     @relation(fields: [leaderId], references: [id])
  apiKeys              AgentApiKey[]
  stakes               AgentStake[]
  asymmetricStrategies AsymmetricStrategy[]
  strategies           Strategy[]
  executions           ExecutionLog[]

  @@index([agentType, isActive])
  @@index([stakingTier, isActive])
  @@index([lastActiveAt])
}

model AgentApiKey {
  id          String                 @id @default(uuid())
  agentId     String
  label       String                 @default("default")
  keyPrefix   String
  keyHash     String                 @unique
  permissions AgentApiKeyPermission[]
  expiresAt   DateTime
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  lastUsedIp  String?
  createdAt   DateTime               @default(now())

  agent Agent @relation(fields: [agentId], references: [id])

  @@index([agentId, revokedAt])
  @@index([keyHash])
}

model AgentStake {
  id                   String           @id @default(uuid())
  agentId              String
  amount               Decimal          @db.Decimal(36, 18)
  token                String           @default("LUNES")
  status               AgentStakeStatus @default(STAKED)
  txHash               String?
  stakedAt             DateTime         @default(now())
  unstakeRequestedAt   DateTime?
  unstakeCompletedAt   DateTime?
  slashedAt            DateTime?
  slashReason          String?

  agent Agent @relation(fields: [agentId], references: [id])

  @@index([agentId, status])
  @@index([status])
}

// ─── Token Listing System ────────────────────────────────────────

enum ListingTier {
  BASIC     // Tier 1: 1 000 LUNES fee, 2 000 LUNES liq, 90 days
  VERIFIED  // Tier 2: 5 000 LUNES fee, 10 000 LUNES liq, 120 days
  FEATURED  // Tier 3: 20 000 LUNES fee, 50 000 LUNES liq, 180 days
}

enum ListingStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum LockStatus {
  LOCKED
  UNLOCKED
  WITHDRAWN
}

model TokenListing {
  id               String        @id @default(uuid())
  ownerAddress     String
  tokenAddress     String        @unique
  tokenName        String
  tokenSymbol      String
  tokenDecimals    Int           @default(18)
  pairAddress      String?
  tier             ListingTier
  status           ListingStatus @default(PENDING)
  listingFee       Decimal       @db.Decimal(36, 18)
  lunesLiquidity   Decimal       @db.Decimal(36, 18)
  tokenLiquidity   Decimal       @db.Decimal(36, 18)
  lpAmount         Decimal       @default(0) @db.Decimal(36, 18)
  onChainListingId Int?
  txHash           String?
  logoURI          String?
  verifiedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  liquidityLock LiquidityLock?

  @@index([ownerAddress])
  @@index([status, tier])
  @@index([createdAt])
}

model LiquidityLock {
  id              String      @id @default(uuid())
  listingId       String      @unique
  ownerAddress    String
  pairAddress     String
  lpTokenAddress  String
  lpAmount        Decimal     @db.Decimal(36, 18)
  lunesLocked     Decimal     @db.Decimal(36, 18)
  tokenLocked     Decimal     @db.Decimal(36, 18)
  tier            ListingTier
  status          LockStatus  @default(LOCKED)
  unlockAt        DateTime
  onChainLockId   Int?
  txHashLock      String?
  txHashUnlock    String?
  withdrawnAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  listing TokenListing @relation(fields: [listingId], references: [id])

  @@index([ownerAddress, status])
  @@index([unlockAt, status])
}

// ─── Token Registry (off-chain metadata) ─────────────────────────
// Trusted token metadata. Auto-populated when a listing is activated.
// Also supports manual admin entries for seed tokens (LUNES, USDT, etc.)

model TokenRegistry {
  id         String   @id @default(uuid())
  address    String   @unique
  symbol     String
  name       String
  decimals   Int      @default(18)
  logoURI    String?
  isVerified Boolean  @default(false)
  isTrusted  Boolean  @default(false)
  source     String   @default("LISTING") // LISTING | ADMIN | SEED
  listingId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([symbol])
  @@index([isVerified])
}

// ─── Asymmetric Liquidity V2 ─────────────────────────────────────

enum AsymmetricStrategyStatus {
  ACTIVE
  COOLING_DOWN
  SUSPENDED_ERROR
  PAUSED
}

enum AsymmetricCurveSide {
  BUY
  SELL
}

model AsymmetricStrategy {
  id               String                   @id @default(uuid())
  userAddress      String                   // LP wallet address (sr25519)
  pairAddress      String                   // AsymmetricPair ink! contract address
  agentId          String?                  // null = backend Sentinel; set = AI agent (OpenClaw)

  // Automation control
  isAutoRebalance  Boolean                  @default(true)
  status           AsymmetricStrategyStatus @default(ACTIVE)
  lastRebalancedAt DateTime?
  pendingAmount    Decimal                  @default(0) @db.Decimal(36, 18)

  // Buy curve parameters
  buyK             Decimal                  @db.Decimal(36, 18) // base liquidity
  buyGamma         Int                                          // curvature 1-5
  buyMaxCapacity   Decimal                  @db.Decimal(36, 18)
  buyFeeTargetBps  Int                      @default(30)

  // Sell curve parameters
  sellGamma           Int
  sellMaxCapacity     Decimal               @db.Decimal(36, 18)
  sellFeeTargetBps    Int                   @default(30)
  sellProfitTargetBps Int                   @default(500)  // 5% profit target

  // Leverage integration (links to MarginAccount)
  leverageL  Decimal @default(0)   @db.Decimal(36, 18)
  allocationC Decimal @default(0.5) @db.Decimal(10, 4)

  // Sentinel retry tracking
  retryCount Int     @default(0)
  lastError  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent         Agent?                  @relation(fields: [agentId], references: [id])
  rebalanceLogs AsymmetricRebalanceLog[]

  @@index([userAddress, status])
  @@index([pairAddress])
  @@index([agentId])
  @@index([status, lastRebalancedAt])
}

model AsymmetricRebalanceLog {
  id             String              @id @default(uuid())
  strategyId     String
  side           AsymmetricCurveSide
  trigger        String              // AUTO_REBALANCER | AI_AGENT | MANUAL
  acquiredAmount Decimal             @db.Decimal(36, 18)
  newCapacity    Decimal             @db.Decimal(36, 18)
  txHash         String?
  gasConsumed    Decimal?            @db.Decimal(36, 18)
  status         String              @default("SUCCESS") // SUCCESS | FAILED | SKIPPED_DUST
  createdAt      DateTime            @default(now())

  strategy AsymmetricStrategy @relation(fields: [strategyId], references: [id])

  @@index([strategyId, createdAt])
  @@index([status, createdAt])
}

// ─── AI Trading Network: Execution Layer ────────────────────────────────────

enum ExecutionStatus {
  PENDING   // Submitted to orderbook, awaiting fill
  EXECUTED  // Fully or partially filled
  REJECTED  // Blocked by risk/validation controls
  FAILED    // Technical failure (timeout, rpc error)
}

model ExecutionLog {
  id               String          @id @default(uuid())
  agentId          String
  strategyId       String?         // Optional: linked Strategy
  orderId          String?         // Filled once the Order record exists
  pairSymbol       String
  side             OrderSide
  orderType        String          // MARKET | LIMIT | STOP | STOP_LIMIT
  requestedAmount  Decimal         @db.Decimal(36, 18)
  executedAmount   Decimal?        @db.Decimal(36, 18)
  price            Decimal?        @db.Decimal(36, 18)
  slippageBps      Int?
  status           ExecutionStatus @default(PENDING)
  rejectionReason  String?         @db.Text
  /// JSON map: { check_name: { passed, value, limit } }
  validationChecks Json?
  source           String          @default("API")  // API | WEB3 | COPYTRADE | STRATEGY

  createdAt DateTime @default(now())

  agent    Agent     @relation(fields: [agentId], references: [id])
  strategy Strategy? @relation(fields: [strategyId], references: [id])

  @@index([agentId, createdAt])
  @@index([strategyId, createdAt])
  @@index([status, createdAt])
  @@index([pairSymbol, createdAt])
}

// ─── AI Trading Network: Strategy Layer ────────────────────────────────────

model Strategy {
  id                  String            @id @default(uuid())
  agentId             String
  leaderId            String?           // Optional: mirrors a Leader's performance
  vaultAddress        String?           // Optional: on-chain CopyVault contract address
  name                String
  description         String?           @db.Text
  strategyType        StrategyType      @default(CUSTOM)
  riskLevel           StrategyRiskLevel @default(MEDIUM)
  status              StrategyStatus    @default(ACTIVE)
  isPublic            Boolean           @default(true)

  // Performance metrics — synced by reputation engine from LeaderAnalyticsSnapshot
  roi30d              Decimal           @default(0) @db.Decimal(20, 8)
  roi7d               Decimal           @default(0) @db.Decimal(20, 8)
  roi1d               Decimal           @default(0) @db.Decimal(20, 8)
  sharpeRatio         Decimal           @default(0) @db.Decimal(20, 8)
  maxDrawdown         Decimal           @default(0) @db.Decimal(20, 8)
  winRate             Decimal           @default(0) @db.Decimal(10, 4)
  totalTrades         Int               @default(0)
  followersCount      Int               @default(0)
  totalVolume         Decimal           @default(0) @db.Decimal(36, 18)
  vaultEquity         Decimal           @default(0) @db.Decimal(36, 18)

  performanceSyncedAt DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  agent       Agent               @relation(fields: [agentId], references: [id])
  leader      Leader?             @relation(fields: [leaderId], references: [id])
  followers   StrategyFollow[]
  performance StrategyPerformance[]
  executions  ExecutionLog[]

  @@index([agentId])
  @@index([leaderId])
  @@index([strategyType, status, isPublic])
  @@index([status, isPublic, roi30d])
  @@index([followersCount])
}

model StrategyFollow {
  id               String   @id @default(uuid())
  strategyId       String
  followerAddress  String
  /// LUNES or vault shares allocated to this strategy
  allocatedCapital Decimal  @default(0) @db.Decimal(36, 18)
  isActive         Boolean  @default(true)
  followedAt       DateTime @default(now())
  unfollowedAt     DateTime?

  strategy Strategy @relation(fields: [strategyId], references: [id])

  @@unique([strategyId, followerAddress])
  @@index([followerAddress, isActive])
  @@index([strategyId, isActive])
}

model StrategyPerformance {
  id         String   @id @default(uuid())
  strategyId String
  /// Daily snapshot — start of day UTC
  date       DateTime
  roi        Decimal  @db.Decimal(20, 8)
  pnl        Decimal  @db.Decimal(36, 18)
  volume     Decimal  @db.Decimal(36, 18)
  trades     Int      @default(0)
  equity     Decimal  @db.Decimal(36, 18)
  drawdown   Decimal  @db.Decimal(20, 8)

  strategy Strategy @relation(fields: [strategyId], references: [id])

  @@unique([strategyId, date])
  @@index([strategyId, date])
}

// ─── Governance Vote Cooldown ────────────────────────────────────────────────
// Tracks on-chain vote submissions per wallet per proposal.
// Used for server-side cooldown enforcement (1h minimum between votes).

model GovernanceVote {
  id           String   @id @default(uuid())
  walletAddress String
  proposalId   Int
  voteType     String   // YES | NO
  txHash       String?
  votedAt      DateTime @default(now())

  @@unique([walletAddress, proposalId, voteType])
  @@index([walletAddress, proposalId])
  @@index([votedAt])
}

// ─── User Favorite Pairs ─────────────────────────────────────────────────────
// Stores per-wallet favorite trading pairs for quick access.
// Synced from frontend localStorage when wallet is connected.

model Favorite {
  id            String   @id @default(uuid())
  walletAddress String
  pairSymbol    String
  createdAt     DateTime @default(now())

  @@unique([walletAddress, pairSymbol])
  @@index([walletAddress])
}

// ─── Weekly Reward Distribution ──────────────────────────────────────────────
// Tracks weekly fee collection and reward pool distribution cycles.
// Fee split: 40% LP (AMM), 40% Treasury, 20% Reward Pool.
// Reward pool split is config-driven across leaders, traders and stakers and
// must total 100% (`LEADER_POOL_PCT + TRADER_POOL_PCT + STAKER_POOL_PCT`).
// `traderPoolAmount` is derived at runtime from `rewardPoolAmount - leaderPoolAmount - stakerPoolAmount`
// to preserve backward compatibility with the persisted schema.
// Staker rewards are funded on-chain via the staking contract, not materialized per-wallet here.

model RewardWeek {
  id                 String    @id @default(uuid())
  weekStart          DateTime
  weekEnd            DateTime
  totalFeesCollected Decimal   @default(0) @db.Decimal(36, 18)
  rewardPoolAmount   Decimal   @default(0) @db.Decimal(36, 18)
  leaderPoolAmount   Decimal   @default(0) @db.Decimal(36, 18)
  stakerPoolAmount   Decimal   @default(0) @db.Decimal(36, 18)
  status             String    @default("ACCUMULATING") // ACCUMULATING | DISTRIBUTED
  distributedAt      DateTime?
  createdAt          DateTime  @default(now())

  rewards UserReward[]

  @@unique([weekStart])
  @@index([status])
}

model UserReward {
  id            String    @id @default(uuid())
  rewardWeekId  String
  walletAddress String
  amount        Decimal   @db.Decimal(36, 18)
  rewardType    String    // LEADER | TRADER (staker claims live on-chain)
  rank          Int?
  weight        Decimal?  @db.Decimal(36, 18)
  claimed       Boolean   @default(false)
  claimedAt     DateTime?
  txHash        String?   // On-chain payout tx hash
  payoutStatus  String    @default("PENDING") // PENDING | SUBMITTED | CONFIRMED | FAILED
  payoutError   String?
  createdAt     DateTime  @default(now())

  rewardWeek RewardWeek @relation(fields: [rewardWeekId], references: [id])

  @@index([walletAddress, claimed])
  @@index([rewardWeekId])
  @@index([payoutStatus])
}
