# ═══════════════════════════════════════════════════════════════
# Lunex DEX — .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Dependencies ──
node_modules/
package-lock.json
yarn.lock

# ── Build artifacts ──
**/target/
/artifacts/
dist/
build/
.next/
/types/
*.rs.bk

# ── Environment & Secrets ──
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
.env.docker
.env.prod
.env.sandbox
**/.env
!**/.env.example
!**/.env.*.example

# ── Secrets gerados (gen-secrets.sh) ──
secrets.env
secrets*.env
*.secrets
.secrets

# ── IDE & Editors ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── AI Agent / IDE Config (DO NOT COMMIT) ──
.agent/
.gemini/
.cursor/
.copilot/
.aider*
.continue/
GEMINI.md

# ── OS generated ──
.DS_Store
Thumbs.db
*.log

# ── Docker data volumes ──
docker/data/
docker/certbot/
docker/ssl/

# ── Test / Coverage ──
coverage/
.nyc_output/
*.lcov

# ── Miscellaneous ──
*.tgz
*.tar.gz
tmp/

# ── Subprojects ──
# lunex-admin/ has its own git repo (with own remote) — excluded here.
# subquery-node/ is committed alongside the rest of the project (no separate repo).
lunex-admin/
