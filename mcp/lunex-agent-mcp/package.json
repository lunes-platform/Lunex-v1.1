{
  "name": "@lunex/spot-social-copytrade-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test src/*.test.ts",
    "smoke:router": "node dist/smokeRouter.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:write": "prettier --write \"src/**/*.ts\"",
    "deadcode:exports": "ts-prune -p tsconfig.json --error",
    "deadcode:deps": "depcheck . --json --ignore-dirs=dist",
    "quality": "npm run lint && npm run deadcode:exports && npm run deadcode:deps && npm run format:check",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@types/node": "^25.6.0",
    "depcheck": "^1.4.7",
    "eslint": "^8.57.1",
    "prettier": "^3.6.2",
    "ts-prune": "^0.10.3",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3"
  }
}
