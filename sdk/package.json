{
    "name": "@lunex/sdk",
    "version": "1.0.0",
    "description": "Official TypeScript SDK for Lunex DEX - Decentralized Exchange on Lunes Network",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "jest",
        "test:watch": "jest --watch",
        "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
        "format": "prettier --write \"src/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\"",
        "deadcode:exports": "ts-prune -p tsconfig.json -i \"src/index\\\\.ts\" --error",
        "deadcode:deps": "depcheck . --json --ignore-dirs=dist,examples --ignores=@types/jest,@types/node",
        "quality": "npm run lint && npm run deadcode:exports && npm run deadcode:deps && npm run format:check",
        "prepublishOnly": "npm run build && npm test"
    },
    "keywords": [
        "lunex",
        "dex",
        "defi",
        "blockchain",
        "lunes",
        "swap",
        "liquidity",
        "staking",
        "polkadot",
        "substrate"
    ],
    "author": "Lunex DEX Team",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/lunex-dex/sdk"
    },
    "bugs": {
        "url": "https://github.com/lunex-dex/sdk/issues"
    },
    "homepage": "https://lunex.io",
    "dependencies": {
        "axios": "^1.6.0",
        "socket.io-client": "^4.6.0",
        "eventemitter3": "^5.0.1"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^20.10.0",
        "@typescript-eslint/eslint-plugin": "^6.13.0",
        "@typescript-eslint/parser": "^6.13.0",
        "depcheck": "^1.4.7",
        "eslint": "^8.54.0",
        "jest": "^29.7.0",
        "prettier": "^3.1.0",
        "ts-prune": "^0.10.3",
        "ts-jest": "^29.1.0",
        "typescript": "^5.3.0"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=16.0.0"
    }
}
